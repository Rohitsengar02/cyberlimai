rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users profile and nested collections rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Chat history rules matching the client implementation path
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // API keys root rules
    match /apiKeys/{apiKey} {
      allow get: if true; // Safe since the document ID is the secret API key itself
      allow list, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }
  }
}
